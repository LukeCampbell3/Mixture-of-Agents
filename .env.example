# =============================================================================
# Mixture-of-Agents CLI — Environment Configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Options: auto, ollama, openai, anthropic
# "auto" picks the fastest available provider at startup.
DEFAULT_LLM_PROVIDER=auto

# ── API Keys (only needed for cloud providers) ────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Ollama (local) ────────────────────────────────────────────────────────────
# Default: http://localhost:11434
# In Docker: http://ollama:11434  or  http://host.docker.internal:11434
OLLAMA_BASE_URL=http://localhost:11434

# ── Runtime defaults ──────────────────────────────────────────────────────────
# Budget mode: low | balanced | thorough | codebase
DEFAULT_BUDGET_MODE=balanced

# Data directory for agent registry, artifacts, calibration
DATA_DIR=data
